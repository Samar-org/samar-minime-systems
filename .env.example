# =============================================================================
# Samar-Minime Systems — Environment Configuration
# =============================================================================

# --- Database ---
DATABASE_URL=postgresql://samar:samar_secret@localhost:5432/samar_minime
REDIS_URL=redis://localhost:6379

# --- AI Providers ---
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
LLAMA_BASE_URL=http://localhost:11434/v1

# --- S3 Storage ---
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=samar-artifacts
S3_REGION=us-east-1

# --- Temporal ---
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=samar-minime

# --- API ---
API_PORT=3000
API_HOST=0.0.0.0
API_LOG_LEVEL=info

# --- Dashboard ---
NEXT_PUBLIC_API_URL=http://localhost:3000

# --- Cost Control ---
DEFAULT_PROJECT_BUDGET_USD=100.00
DEFAULT_TASK_BUDGET_USD=5.00
MAX_ESCALATION_RETRIES=3

# --- Model Defaults ---
UTILITY_MODEL=gpt-3.5-turbo
BUILDER_MODEL=gpt-4o-mini
DIRECTOR_MODEL=gpt-4o
SPECIALIST_MODEL=claude-sonnet-4-20250514

# --- Llama Fleet (hosted vLLM cluster) ---
LLAMA_FLEET_ENABLED=false
LLAMA_FLEET_URL=http://your-gpu-server:8080
LLAMA_FLEET_API_KEY=sk-llama-prod-key-1
