# ============================================================================
# Samar-Minime Llama Worker Fleet — Environment Configuration
# ============================================================================

# ── Hugging Face (required to download model weights) ────────────────────────
HF_TOKEN=hf_your_token_here

# ── API Authentication ───────────────────────────────────────────────────────
# Comma-separated list of valid API keys
LLAMA_API_KEYS=sk-llama-prod-key-1,sk-llama-prod-key-2

# ── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_RPM=600          # Requests per minute per key
RATE_LIMIT_TPM=1000000      # Tokens per minute per key

# ── vLLM 70B Configuration ──────────────────────────────────────────────────
VLLM_70B_TP_SIZE=4          # Tensor parallel across N GPUs (need 4x A100 for 70B)
VLLM_70B_QUANTIZATION=awq   # awq | gptq | squeezellm | none

# ── Worker Configuration ────────────────────────────────────────────────────
WORKER_CONCURRENCY=16       # Parallel tasks the worker processes
WORKER_BATCH_SIZE=8          # Batch size for grouped inference

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info               # debug | info | warning | error

# ── Monitoring ───────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=admin

# ── GPU Cloud Provider (set based on your provider) ──────────────────────────
# AWS:        p4d.24xlarge (8x A100 80GB) = ~$32.77/hr
# GCP:        a2-highgpu-4g (4x A100 40GB) = ~$14.69/hr
# Lambda:     gpu_4x_a100 (4x A100) = ~$5.20/hr
# Paperspace: A100-80Gx4 = ~$12.40/hr
# RunPod:     4x A100 80GB = ~$7.44/hr
