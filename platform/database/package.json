{
  "name": "@samar/database",
  "version": "0.1.0",
  "description": "Prisma ORM and database migrations for Samar",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "prisma generate && node --watch -r esbuild-register src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --outfile=dist/index.js && tsc --declaration --emitDeclarationOnly --outDir dist",
    "migrate:dev": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "generate": "prisma generate",
    "seed": "node -r esbuild-register src/seeds/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.8.0",
    "@samar/config": "workspace:*",
    "@samar/observability": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "esbuild": "^0.19.0",
    "esbuild-register": "^3.5.0",
    "prisma": "^5.8.0",
    "typescript": "^5.3.0"
  }
}
