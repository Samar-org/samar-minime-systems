{
  "name": "@samar/evaluation",
  "version": "0.1.0",
  "description": "Task and workflow evaluation engine",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "node --watch -r esbuild-register src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --outfile=dist/index.js && tsc --declaration --emitDeclarationOnly --outDir dist",
    "test": "vitest"
  },
  "dependencies": {
    "@samar/observability": "workspace:*",
    "@samar/schemas": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "esbuild": "^0.19.0",
    "esbuild-register": "^3.5.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
